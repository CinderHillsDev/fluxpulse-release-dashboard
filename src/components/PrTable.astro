---
import type { PR } from '@/types';

interface Props {
  prs: PR[];
}

const { prs } = Astro.props;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  const now = new Date();
  const diffMs = now.getTime() - date.getTime();
  const diffH = Math.floor(diffMs / (1000 * 60 * 60));
  const diffD = Math.floor(diffH / 24);

  if (diffD > 0) return `${diffD}d`;
  if (diffH > 0) return `${diffH}h`;
  return 'now';
}
---

{prs.length === 0 ? (
  <div class="text-center py-12">
    <p class="text-slate-600">No open pull requests</p>
  </div>
) : (
  <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
    <table class="w-full">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr>
          <th class="text-left px-6 py-3 text-sm font-semibold text-slate-900">Repo</th>
          <th class="text-left px-6 py-3 text-sm font-semibold text-slate-900">PR</th>
          <th class="text-left px-6 py-3 text-sm font-semibold text-slate-900">Title</th>
          <th class="text-left px-6 py-3 text-sm font-semibold text-slate-900">Author</th>
          <th class="text-left px-6 py-3 text-sm font-semibold text-slate-900">Age</th>
          <th class="text-left px-6 py-3 text-sm font-semibold text-slate-900">Labels</th>
        </tr>
      </thead>
      <tbody>
        {prs.map((pr, i) => (
          <tr class={i % 2 === 0 ? 'bg-white' : 'bg-slate-50'}>
            <td class="px-6 py-3 text-sm text-slate-600">{pr.repo}</td>
            <td class="px-6 py-3 text-sm text-slate-600">
              <a href={pr.url} target="_blank" rel="noreferrer" class="text-blue-600 hover:underline">
                #{pr.number}
              </a>
            </td>
            <td class="px-6 py-3 text-sm text-slate-900 font-medium">
              <a href={pr.url} target="_blank" rel="noreferrer" class="hover:text-blue-600">
                {pr.title}
              </a>
            </td>
            <td class="px-6 py-3 text-sm text-slate-600">{pr.author}</td>
            <td class="px-6 py-3 text-sm text-slate-600">{formatDate(pr.createdAt)}</td>
            <td class="px-6 py-3 text-sm">
              <div class="flex flex-wrap gap-2">
                {pr.labels.map((label) => (
                  <span class="inline-block px-2 py-1 text-xs bg-slate-200 text-slate-700 rounded">
                    {label}
                  </span>
                ))}
              </div>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}
