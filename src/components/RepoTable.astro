---
import type { RepoStatus } from '@/types';
import { NO_DEPLOY_REPOS } from '@/repos';

interface Props {
  repos: RepoStatus[];
}

const { repos } = Astro.props;
const csrfToken = Astro.locals.csrfToken;

function formatAge(dateStr: string | null): string {
  if (!dateStr) return '—';
  const ms = Date.now() - new Date(dateStr).getTime();
  const h = Math.floor(ms / 3_600_000);
  const d = Math.floor(h / 24);
  if (d > 0) return `${d}d`;
  if (h > 0) return `${h}h`;
  const m = Math.floor(ms / 60_000);
  return m > 0 ? `${m}m` : 'now';
}

const syncStyles: Record<RepoStatus['syncState'], { dot: string; label: string; tooltip: string }> = {
  'in-sync': { dot: 'bg-green-500', label: 'in sync', tooltip: 'UAT matches main HEAD' },
  'uat-ahead': { dot: 'bg-amber-500', label: 'uat ahead', tooltip: 'UAT has commits not yet in prod' },
  'never-deployed': { dot: 'bg-slate-400', label: 'never deployed', tooltip: 'No deployment records for this repo' },
  'unknown': { dot: 'bg-slate-400', label: '—', tooltip: 'No releases yet' },
};

function ciDot(repo: RepoStatus): string {
  if (repo.ciStatus === 'in_progress' || repo.ciStatus === 'queued') return 'bg-yellow-400 animate-pulse';
  if (repo.ciConclusion === 'success') return 'bg-green-500';
  if (repo.ciConclusion === 'failure') return 'bg-red-500';
  if (repo.ciConclusion === 'cancelled') return 'bg-slate-400';
  if (repo.ciConclusion) return 'bg-slate-400';
  return 'bg-slate-300';
}

function ciTooltip(repo: RepoStatus): string {
  if (repo.ciStatus === 'in_progress' || repo.ciStatus === 'queued') return 'CI: running';
  return `CI: ${repo.ciConclusion ?? '—'}`;
}

function deployDot(conclusion: RepoStatus['uatDeploy']): string {
  if (!conclusion) return 'bg-slate-300';
  if (conclusion.conclusion === 'success') return 'bg-green-500';
  if (conclusion.conclusion === 'failure') return 'bg-red-500';
  return 'bg-yellow-400 animate-pulse';
}
---

<!-- Sticky action bar (hidden until ≥1 checkbox is checked) -->
<div
  id="batch-bar"
  class="hidden sticky top-0 z-10 mb-3 flex items-center gap-3 rounded-lg border border-blue-200 bg-blue-50 px-4 py-2.5 shadow-sm"
>
  <span id="batch-count" class="text-sm font-medium text-blue-800">0 selected</span>
  <form id="batch-form" method="POST" action="/api/dispatch-batch" class="inline-flex gap-2">
    <!-- repos[] inputs are injected by JS -->
    <button
      type="submit"
      class="px-3 py-1 text-xs font-medium bg-blue-600 text-white rounded hover:bg-blue-700 transition"
    >
      Release selected to UAT
    </button>
  </form>
</div>

<div class="overflow-x-auto border border-slate-200 rounded-lg bg-white">
  <table class="min-w-full text-sm">
    <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-600">
      <tr>
        <th class="px-4 py-3 w-8">
          <input
            type="checkbox"
            id="check-all"
            class="cursor-pointer accent-blue-600"
            title="Select all eligible repos"
          />
        </th>
        <th class="text-left font-semibold px-4 py-3">Repo</th>
        <th class="text-left font-semibold px-3 py-3" title="CI · UAT deploy · Prod deploy">Pipeline</th>
        <th class="text-left font-semibold px-3 py-3">Sync</th>
        <th class="text-left font-semibold px-3 py-3">Tag</th>
        <th class="text-left font-semibold px-3 py-3">UAT</th>
        <th class="text-left font-semibold px-3 py-3">Prod</th>
        <th class="text-right font-semibold px-3 py-3" title="Open pull requests">PRs</th>
        <th class="text-right font-semibold px-3 py-3" title="Commits on main not yet released">Unreleased</th>
        <th class="text-right font-semibold px-4 py-3">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      {repos.map((repo) => {
        const sync = syncStyles[repo.syncState];
        return (
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-2.5 w-8">
              {!repo.releaseOnly && !NO_DEPLOY_REPOS.has(repo.name as any) && (repo.unreleasedCommits > 0 || repo.uatDeploy?.conclusion === 'failure') ? (
                <input
                  type="checkbox"
                  class="repo-checkbox cursor-pointer accent-blue-600"
                  data-repo={repo.name}
                  title={`Select ${repo.name}`}
                />
              ) : (
                <span />
              )}
            </td>
            <td class="px-4 py-2.5 font-medium text-slate-900">
              <a
                href={`https://github.com/CinderHillsDev/${repo.name}`}
                target="_blank"
                rel="noreferrer"
                class="hover:underline"
              >
                {repo.name}
              </a>
            </td>
            <td class="px-3 py-2.5">
              <div class="inline-flex gap-3 items-end">
                {/* CI dot */}
                <a
                  href={repo.ciRunUrl ?? `https://github.com/CinderHillsDev/${repo.name}/actions`}
                  target="_blank"
                  rel="noreferrer"
                  class="flex flex-col items-center gap-0.5 hover:opacity-70"
                  title={ciTooltip(repo)}
                >
                  <span class="text-[9px] font-semibold text-slate-400 leading-none">CI</span>
                  <span class={`inline-block w-2.5 h-2.5 rounded-full ${ciDot(repo)}`}></span>
                </a>
                {/* UAT deploy dot — omitted for release-only repos (no UAT stage) */}
                {!repo.releaseOnly && (
                  <a
                    href={repo.uatDeploy?.runUrl ?? `https://github.com/CinderHillsDev/${repo.name}/actions`}
                    target="_blank"
                    rel="noreferrer"
                    class="flex flex-col items-center gap-0.5 hover:opacity-70"
                    title={`UAT deploy: ${repo.uatDeploy?.conclusion ?? 'none'}`}
                  >
                    <span class="text-[9px] font-semibold text-slate-400 leading-none">UAT</span>
                    <span class={`inline-block w-2.5 h-2.5 rounded-full ${deployDot(repo.uatDeploy)}`}></span>
                  </a>
                )}
                {/* Prod deploy dot — omitted for non-deployable repos */}
                {!NO_DEPLOY_REPOS.has(repo.name as any) && (
                  <a
                    href={repo.prodDeploy?.runUrl ?? `https://github.com/CinderHillsDev/${repo.name}/actions`}
                    target="_blank"
                    rel="noreferrer"
                    class="flex flex-col items-center gap-0.5 hover:opacity-70"
                    title={`Prod deploy: ${repo.prodDeploy?.conclusion ?? 'none'}`}
                  >
                    <span class="text-[9px] font-semibold text-slate-400 leading-none">PRD</span>
                    <span class={`inline-block w-2.5 h-2.5 rounded-full ${deployDot(repo.prodDeploy)}`}></span>
                  </a>
                )}
              </div>
            </td>
            <td class="px-3 py-2.5">
              <span class="inline-flex items-center gap-1.5" title={sync.tooltip}>
                <span class={`inline-block w-2 h-2 rounded-full ${sync.dot}`}></span>
                <span class="text-xs text-slate-700">{sync.label}</span>
              </span>
            </td>
            <td class="px-3 py-2.5 font-mono text-xs text-slate-700">{repo.latestTag || '—'}</td>
            <td class="px-3 py-2.5 font-mono text-xs">
              {repo.releaseOnly ? (
                <span class="text-slate-400 italic text-[11px]">n/a</span>
              ) : repo.uatDeploy ? (
                <a href={repo.uatDeploy.runUrl} target="_blank" rel="noreferrer" class="hover:underline text-slate-900">
                  {repo.uatDeploy.version}
                  <span class="ml-1.5 text-slate-400">·</span>
                  <span class="ml-1.5 text-slate-500">{formatAge(repo.uatDeploy.runAt)}</span>
                  {repo.uatHealth === 'up' && (
                    <sup class="ml-1 text-green-500" title="UAT health: up">●</sup>
                  )}
                  {repo.uatHealth === 'down' && (
                    <sup class="ml-1 text-red-500" title="UAT health: down">●</sup>
                  )}
                </a>
              ) : (
                <span class="text-slate-400">—</span>
              )}
            </td>
            <td class="px-3 py-2.5 font-mono text-xs">
              {repo.prodDeploy ? (
                <a href={repo.prodDeploy.runUrl} target="_blank" rel="noreferrer" class="hover:underline text-slate-900">
                  {repo.prodDeploy.version}
                  <span class="ml-1.5 text-slate-400">·</span>
                  <span class="ml-1.5 text-slate-500">{formatAge(repo.prodDeploy.runAt)}</span>
                  {repo.prodHealth === 'up' && (
                    <sup class="ml-1 text-green-500" title="Prod health: up">●</sup>
                  )}
                  {repo.prodHealth === 'down' && (
                    <sup class="ml-1 text-red-500" title="Prod health: down">●</sup>
                  )}
                </a>
              ) : (
                <span class="text-slate-400">—</span>
              )}
            </td>
            <td class="px-3 py-2.5 text-right text-slate-700">{repo.openPrCount}</td>
            <td class="px-3 py-2.5 text-right">
              {repo.unreleasedCommits > 0 ? (
                <span class="text-amber-700 font-semibold">{repo.unreleasedCommits}</span>
              ) : (
                <span class="text-slate-400">0</span>
              )}
            </td>
            <td class="px-4 py-2.5 text-right">
              <div class="inline-flex gap-1.5">
                {repo.ciConclusion === 'failure' || repo.ciConclusion === 'cancelled' ? (
                  <form method="POST" action="/api/rerun-ci" class="inline-block" onsubmit="return window.submitRerunCi(event)">
                    <input type="hidden" name="astro.csrf" value={csrfToken} />
                    <input type="hidden" name="repo" value={repo.name} />
                    <button
                      type="submit"
                      class="w-20 px-2.5 py-1 text-xs font-medium bg-orange-600 text-white rounded hover:bg-orange-700 transition text-center"
                      title={`CI ${repo.ciConclusion} — retry the workflow`}
                    >
                      Retry CI
                    </button>
                  </form>
                ) : null}
                {repo.releaseOnly ? (
                  /* Agent/binary repos are released by pushing a v* tag — no dispatch button */
                  repo.unreleasedCommits > 0 && (
                    <a
                      href={`https://github.com/CinderHillsDev/${repo.name}/releases`}
                      target="_blank"
                      rel="noreferrer"
                      class="w-24 px-2.5 py-1 text-xs font-medium bg-slate-600 text-white rounded hover:bg-slate-700 transition text-center inline-block"
                      title="View releases on GitHub"
                    >
                      View releases ↗
                    </a>
                  )
                ) : !NO_DEPLOY_REPOS.has(repo.name as any) ? (
                  <>
                    {(repo.unreleasedCommits > 0 || repo.uatDeploy?.conclusion === 'failure') && (
                      <form method="POST" action="/api/dispatch" class="inline-block" onsubmit="return window.submitDispatch(event)">
                        <input type="hidden" name="astro.csrf" value={csrfToken} />
                        <input type="hidden" name="repo" value={repo.name} />
                        <button
                          type="submit"
                          class="w-20 px-2.5 py-1 text-xs font-medium bg-blue-600 text-white rounded hover:bg-blue-700 transition text-center"
                          title={repo.uatDeploy?.conclusion === 'failure' ? 'Last UAT deploy failed — re-dispatch deploy-uat.yml' : 'Dispatch deploy-uat.yml on this repo'}
                        >
                          {repo.uatDeploy?.conclusion === 'failure' ? 'Retry UAT' : 'Release'}
                        </button>
                      </form>
                    )}
                    {repo.syncState === 'uat-ahead' && (
                      <form method="POST" action="/api/dispatch" class="inline-block" onsubmit="return window.submitDispatch(event)">
                        <input type="hidden" name="astro.csrf" value={csrfToken} />
                        <input type="hidden" name="repo" value={repo.name} />
                        <input type="hidden" name="workflow" value="deploy-prod" />
                        <button
                          type="submit"
                          class="w-24 px-2.5 py-1 text-xs font-medium bg-green-600 text-white rounded hover:bg-green-700 transition text-center"
                          title="Dispatch deploy-prod.yml on this repo"
                        >
                          Deploy Prod
                        </button>
                      </form>
                    )}
                  </>
                ) : null}
                <button
                  type="button"
                  onclick={`window.refreshRepo('${repo.name}')`}
                  data-refresh={repo.name}
                  class="px-2.5 py-1 text-xs font-medium bg-slate-300 text-slate-700 rounded hover:bg-slate-400 transition"
                  title="Refresh this repo's status"
                >
                  ↻
                </button>
              </div>
            </td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>

<script>
  const bar = document.getElementById('batch-bar') as HTMLDivElement;
  const countEl = document.getElementById('batch-count') as HTMLSpanElement;
  const form = document.getElementById('batch-form') as HTMLFormElement;
  const checkAll = document.getElementById('check-all') as HTMLInputElement;
  const checkboxes = () => Array.from(document.querySelectorAll<HTMLInputElement>('.repo-checkbox'));

  function syncBar() {
    const checked = checkboxes().filter((cb) => cb.checked);
    const n = checked.length;
    if (n > 0) {
      bar.classList.remove('hidden');
      bar.classList.add('flex');
      countEl.textContent = `${n} selected`;
      // Rebuild repos[] hidden inputs
      form.querySelectorAll('input[name="repos"]').forEach((el) => el.remove());
      for (const cb of checked) {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'repos';
        input.value = cb.dataset.repo ?? '';
        form.appendChild(input);
      }
    } else {
      bar.classList.add('hidden');
      bar.classList.remove('flex');
    }
    // Sync header checkbox state
    const all = checkboxes();
    checkAll.indeterminate = n > 0 && n < all.length;
    checkAll.checked = all.length > 0 && n === all.length;
  }

  checkAll.addEventListener('change', () => {
    checkboxes().forEach((cb) => { cb.checked = checkAll.checked; });
    syncBar();
  });

  document.addEventListener('change', (e) => {
    if ((e.target as HTMLElement).classList.contains('repo-checkbox')) syncBar();
  });
</script>
