---
import type { RepoStatus } from '@/types';

interface Props {
  repos: RepoStatus[];
}

const { repos } = Astro.props;

function formatAge(dateStr: string): string {
  const ms = Date.now() - new Date(dateStr).getTime();
  const h = Math.floor(ms / 3_600_000);
  const d = Math.floor(h / 24);
  if (d > 0) return `${d}d ago`;
  if (h > 0) return `${h}h ago`;
  const m = Math.floor(ms / 60_000);
  return m > 0 ? `${m}m ago` : 'just now';
}

const reposWithQueue = repos.filter(
  (r) =>
    r.pendingUatItems.length > 0 ||
    r.pendingProdItems.length > 0 ||
    r.uatDeploy?.conclusion === 'failure' ||
    r.prodDeploy?.conclusion === 'failure'
);
---

{reposWithQueue.length === 0 ? (
  <div class="text-center py-12 bg-white border border-slate-200 rounded-lg">
    <p class="text-slate-600">Nothing queued for UAT or prod.</p>
    <p class="text-xs text-slate-400 mt-1">Every commit on main has reached its target env.</p>
  </div>
) : (
  <div class="space-y-2">
    {reposWithQueue.map((repo) => {
      const uatFailed = repo.uatDeploy?.conclusion === 'failure';
      const hasUatItems = repo.pendingUatItems.length > 0;
      const hasProdItems = repo.pendingProdItems.length > 0;
      const startOpen = hasUatItems || hasProdItems || uatFailed;
      return (
        <details open={startOpen} class="group bg-white border border-slate-200 rounded-lg overflow-hidden">
          <summary class="flex items-center justify-between px-5 py-3.5 cursor-pointer select-none list-none hover:bg-slate-50 [&::-webkit-details-marker]:hidden">
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-slate-400 transition-transform group-open:rotate-90 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
              <span class="font-semibold text-slate-900">
                <a
                  href={`https://github.com/CinderHillsDev/${repo.name}`}
                  target="_blank"
                  rel="noreferrer"
                  class="hover:underline"
                  onclick="event.stopPropagation()"
                >
                  {repo.name}
                </a>
              </span>
              <div class="flex items-center gap-1.5 text-xs">
                {uatFailed && !hasUatItems && (
                  <span class="px-2 py-0.5 rounded-full bg-red-100 text-red-700 font-medium">deploy failed</span>
                )}
                {hasUatItems && (
                  <span class="px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 font-medium">{repo.pendingUatItems.length} → UAT</span>
                )}
                {hasProdItems && (
                  <span class="px-2 py-0.5 rounded-full bg-green-100 text-green-700 font-medium">{repo.pendingProdItems.length} → Prod</span>
                )}
              </div>
            </div>
            <div class="flex gap-2 shrink-0" onclick="event.stopPropagation()">
              {(hasUatItems || uatFailed) && (
                <form method="POST" action="/api/dispatch">
                  <input type="hidden" name="repo" value={repo.name} />
                  <button
                    type="submit"
                    class="px-3 py-1 text-xs font-medium bg-blue-600 text-white rounded hover:bg-blue-700 transition"
                    title="Dispatch deploy-uat.yml against current main HEAD"
                  >
                    {uatFailed ? 'Retry UAT' : 'Release to UAT'}
                  </button>
                </form>
              )}
              {hasProdItems && (
                <form method="POST" action="/api/dispatch">
                  <input type="hidden" name="repo" value={repo.name} />
                  <input type="hidden" name="workflow" value="deploy-prod" />
                  <button
                    type="submit"
                    class="px-3 py-1 text-xs font-medium bg-green-600 text-white rounded hover:bg-green-700 transition"
                    title="Dispatch deploy-prod.yml — promotes current UAT to prod"
                  >
                    Promote to Prod
                  </button>
                </form>
              )}
            </div>
          </summary>

          <div class="border-t border-slate-100">
            {uatFailed && !hasUatItems && (
              <div class="px-5 py-3 bg-red-50 text-sm text-red-700">
                Last UAT deploy failed. No new commits are pending — click <strong>Retry UAT</strong> to re-run the deployment.
              </div>
            )}

            {hasUatItems && (
              <div>
                <div class="px-5 py-2 bg-blue-50/60 flex items-center gap-2 border-b border-slate-100">
                  <span class="inline-block w-1.5 h-1.5 rounded-full bg-blue-500"></span>
                  <span class="text-xs font-semibold uppercase tracking-wide text-blue-700">Pending UAT</span>
                  <span class="text-xs text-slate-500">— on main, not yet deployed</span>
                </div>
                <table class="w-full text-sm">
                  <tbody class="divide-y divide-slate-100">
                    {repo.pendingUatItems.map((item) => (
                      <tr class="hover:bg-slate-50">
                        <td class="px-5 py-2 w-20 text-slate-500 text-xs font-mono">
                          <a href={item.url} target="_blank" rel="noreferrer" class="hover:text-blue-700 hover:underline">
                            {item.prNumber ? `#${item.prNumber}` : item.shortSha}
                          </a>
                        </td>
                        <td class="py-2 text-slate-900">{item.title}</td>
                        <td class="px-3 py-2 w-32 text-xs text-slate-600">{item.author}</td>
                        <td class="px-5 py-2 w-24 text-right text-xs text-slate-500">{formatAge(item.date)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}

            {hasProdItems && (
              <div>
                <div class="px-5 py-2 bg-green-50/60 flex items-center gap-2 border-b border-slate-100">
                  <span class="inline-block w-1.5 h-1.5 rounded-full bg-green-500"></span>
                  <span class="text-xs font-semibold uppercase tracking-wide text-green-700">Pending Prod</span>
                  <span class="text-xs text-slate-500">— in UAT, not yet promoted to prod</span>
                </div>
                <table class="w-full text-sm">
                  <tbody class="divide-y divide-slate-100">
                    {repo.pendingProdItems.map((item) => (
                      <tr class="hover:bg-slate-50">
                        <td class="px-5 py-2 w-20 text-slate-500 text-xs font-mono">
                          <a href={item.url} target="_blank" rel="noreferrer" class="hover:text-blue-700 hover:underline">
                            {item.prNumber ? `#${item.prNumber}` : item.shortSha}
                          </a>
                        </td>
                        <td class="py-2 text-slate-900">{item.title}</td>
                        <td class="px-3 py-2 w-32 text-xs text-slate-600">{item.author}</td>
                        <td class="px-5 py-2 w-24 text-right text-xs text-slate-500">{formatAge(item.date)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>
        </details>
      );
    })}
  </div>
)}
