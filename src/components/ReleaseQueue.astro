---
import type { RepoStatus } from '@/types';

interface Props {
  repos: RepoStatus[];
}

const { repos } = Astro.props;

function formatAge(dateStr: string): string {
  const ms = Date.now() - new Date(dateStr).getTime();
  const h = Math.floor(ms / 3_600_000);
  const d = Math.floor(h / 24);
  if (d > 0) return `${d}d ago`;
  if (h > 0) return `${h}h ago`;
  const m = Math.floor(ms / 60_000);
  return m > 0 ? `${m}m ago` : 'just now';
}

const reposWithQueue = repos.filter(
  (r) => r.pendingUatPrs.length > 0 || r.pendingProdPrs.length > 0
);
---

{reposWithQueue.length === 0 ? (
  <div class="text-center py-12 bg-white border border-slate-200 rounded-lg">
    <p class="text-slate-600">Nothing queued for UAT or prod.</p>
    <p class="text-xs text-slate-400 mt-1">Every merged PR has reached its target env.</p>
  </div>
) : (
  <div class="space-y-6">
    {reposWithQueue.map((repo) => (
      <div class="bg-white rounded-lg border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
          <div>
            <h3 class="text-lg font-bold text-slate-900">
              <a href={`https://github.com/CinderHillsDev/${repo.name}`} target="_blank" rel="noreferrer" class="hover:underline">
                {repo.name}
              </a>
            </h3>
            <p class="text-xs text-slate-500 mt-0.5">
              {repo.pendingUatPrs.length} pending UAT
              {' · '}
              {repo.pendingProdPrs.length} pending prod
            </p>
          </div>
          <div class="flex gap-2">
            {repo.pendingUatPrs.length > 0 && (
              <form method="POST" action="/api/dispatch">
                <input type="hidden" name="repo" value={repo.name} />
                <button
                  type="submit"
                  class="px-3 py-1.5 text-xs font-medium bg-blue-600 text-white rounded hover:bg-blue-700 transition"
                  title="Dispatch deploy-uat.yml against current main HEAD"
                >
                  Release to UAT
                </button>
              </form>
            )}
            {repo.pendingProdPrs.length > 0 && (
              <form method="POST" action="/api/dispatch">
                <input type="hidden" name="repo" value={repo.name} />
                <input type="hidden" name="workflow" value="deploy-prod" />
                <button
                  type="submit"
                  class="px-3 py-1.5 text-xs font-medium bg-green-600 text-white rounded hover:bg-green-700 transition"
                  title="Dispatch deploy-prod.yml — promotes current UAT to prod"
                >
                  Promote UAT → Prod
                </button>
              </form>
            )}
          </div>
        </div>

        {repo.pendingUatPrs.length > 0 && (
          <div class="border-b border-slate-100">
            <div class="px-6 py-2 bg-blue-50/50 flex items-center gap-2">
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-blue-500"></span>
              <span class="text-xs font-semibold uppercase tracking-wide text-blue-700">Pending UAT</span>
              <span class="text-xs text-slate-500">— merged on main, not yet deployed</span>
            </div>
            <table class="w-full text-sm">
              <tbody class="divide-y divide-slate-100">
                {repo.pendingUatPrs.map((pr) => (
                  <tr class="hover:bg-slate-50">
                    <td class="px-6 py-2 w-16 text-slate-500 text-xs font-mono">
                      <a href={pr.url} target="_blank" rel="noreferrer" class="hover:text-blue-700 hover:underline">#{pr.number}</a>
                    </td>
                    <td class="py-2 text-slate-900">{pr.title}</td>
                    <td class="px-3 py-2 w-32 text-xs text-slate-600">{pr.author}</td>
                    <td class="px-6 py-2 w-24 text-right text-xs text-slate-500">{formatAge(pr.mergedAt)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {repo.pendingProdPrs.length > 0 && (
          <div>
            <div class="px-6 py-2 bg-green-50/50 flex items-center gap-2">
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-green-500"></span>
              <span class="text-xs font-semibold uppercase tracking-wide text-green-700">Pending Prod</span>
              <span class="text-xs text-slate-500">— in UAT, not yet promoted to prod</span>
            </div>
            <table class="w-full text-sm">
              <tbody class="divide-y divide-slate-100">
                {repo.pendingProdPrs.map((pr) => (
                  <tr class="hover:bg-slate-50">
                    <td class="px-6 py-2 w-16 text-slate-500 text-xs font-mono">
                      <a href={pr.url} target="_blank" rel="noreferrer" class="hover:text-blue-700 hover:underline">#{pr.number}</a>
                    </td>
                    <td class="py-2 text-slate-900">{pr.title}</td>
                    <td class="px-3 py-2 w-32 text-xs text-slate-600">{pr.author}</td>
                    <td class="px-6 py-2 w-24 text-right text-xs text-slate-500">{formatAge(pr.mergedAt)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    ))}
  </div>
)}
