---
import { env } from 'cloudflare:workers';
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import ActivityFeed from '@/components/ActivityFeed.astro';
import { fetchActivity } from '@/lib/github';

export const prerender = false;

const typedEnv = env as Env;
const token = typedEnv.GITHUB_TOKEN;
const events = await fetchActivity(token);
---

<Layout title="Release Dashboard - Activity">
  <Navbar currentPage="activity" />
  <main class="max-w-7xl mx-auto px-4 py-8">
    <h2 class="text-2xl font-bold text-slate-900 mb-6">Activity</h2>
    <ActivityFeed events={events} />
  </main>
</Layout>
