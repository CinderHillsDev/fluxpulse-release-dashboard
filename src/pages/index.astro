---
import { env } from '@/lib/env';
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import RepoTable from '@/components/RepoTable.astro';
import { getRepoStatus } from '@/lib/github';

const token = env.CF_GH_PAT_FluxPulseReleaseDashboard;

const repos = await getRepoStatus(token);
const now = new Date().toLocaleString();

const url = new URL(Astro.request.url);
const authError = url.searchParams.get('auth_error');
const dispatchError = url.searchParams.get('dispatch_error');
const dispatchOk = url.searchParams.get('dispatch_ok');
const dispatchRepo = url.searchParams.get('repo') ?? url.searchParams.get('dispatch_ok') ?? '';
const runUrl = url.searchParams.get('run_url') ?? '';

const errorMessages: Record<string, string> = {
  github_rate_limited: 'GitHub rate limit exceeded. Please wait a few minutes before trying to log in again.',
  token_exchange_failed: 'Failed to exchange OAuth code for token. Please try again.',
  user_fetch_failed: 'Failed to fetch user information from GitHub. Please try again.',
  invalid_state: 'Invalid OAuth state. Please try logging in again.',
  env_not_configured: 'Server configuration error. Please contact the administrator.',
  not_org_member: 'You are not a member of the required GitHub organization.',
  callback_error: 'An error occurred during login. Please try again.',
};

const dispatchErrorMessages: Record<string, string> = {
  dispatch_forbidden: `The GitHub token doesn't have Actions write permission. Use a PAT with "Actions: Read and write" scope.`,
  dispatch_unprocessable: `Workflow dispatch was rejected by GitHub (422). The workflow may not have workflow_dispatch enabled or the ref is invalid.`,
  dispatch_failed: `Failed to dispatch the workflow. Check server logs for details.`,
};

const batchOk = url.searchParams.get('batch_ok');
const batchError = url.searchParams.get('batch_error');
---

<Layout title="Release Dashboard - Overview">
  <Navbar currentPage="overview" lastUpdated={now} />

  <main class="max-w-7xl mx-auto px-4 py-8">
    {authError && (
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <p class="text-red-800">
          <strong>Login Error:</strong> {errorMessages[authError] || `An error occurred: ${authError}`}
        </p>
      </div>
    )}
    {dispatchError && (
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <p class="text-red-800">
          <strong>Dispatch failed{dispatchRepo ? ` (${dispatchRepo})` : ''}:</strong> {dispatchErrorMessages[dispatchError] || dispatchError}
        </p>
      </div>
    )}
    {dispatchOk && (
      <div id="dispatch-banner" data-run-url={runUrl} data-repo={dispatchOk} class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg">
        <p class="text-green-800">
          <strong>Dispatched:</strong> workflow triggered for <code class="font-mono">{dispatchOk}</code>.{' '}
          {runUrl ? (
            <a href={runUrl} target="_blank" rel="noreferrer" class="underline font-medium">View run →</a>
          ) : (
            <a href={`https://github.com/${GH_OWNER}/${dispatchOk}/actions`} target="_blank" rel="noreferrer" class="underline font-medium">View on GitHub →</a>
          )}
        </p>
      </div>
    )}
    {dispatchOk && runUrl && (
      <script>
        (function () {
          const banner = document.getElementById('dispatch-banner');
          if (banner && banner.dataset.runUrl) {
            window.pollForRun?.(banner);
          }
        })();
      </script>
    )}

    {batchOk && (
      <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg">
        <p class="text-green-800">
          <strong>Batch dispatched:</strong> workflows triggered for{' '}
          {batchOk.split(',').map((r, i, arr) => (
            <span>
              <code class="font-mono">{r}</code>{i < arr.length - 1 ? ', ' : ''}
            </span>
          ))}.
        </p>
      </div>
    )}
    {batchError && (
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <p class="text-red-800">
          <strong>Batch dispatch failed</strong> for{' '}
          {batchError.split(',').map((r, i, arr) => (
            <span>
              <code class="font-mono">{r}</code>{i < arr.length - 1 ? ', ' : ''}
            </span>
          ))}. Check server logs for details.
        </p>
      </div>
    )}

    <RepoTable repos={repos} />

    <script>
      window.submitDispatch = async function(event) {
        event.preventDefault();
        const form = event.target;
        const repo = form.elements.repo?.value;
        const btn = form.querySelector('button[type="submit"]');

        if (btn) btn.disabled = true;

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form)
          });
          const data = await res.json();

          const main = document.querySelector('main');
          if (!main) return false;

          if (data.ok) {
            const banner = document.createElement('div');
            banner.id = 'dispatch-banner';
            banner.dataset.runUrl = data.runUrl;
            banner.dataset.repo = repo;
            banner.className = 'mb-6 p-4 bg-green-50 border border-green-200 rounded-lg';
            banner.innerHTML = `<p class="text-green-800"><strong>Dispatched:</strong> workflow triggered for <code class="font-mono">${repo}</code>. <a href="${data.runUrl}" target="_blank" rel="noreferrer" class="underline font-medium">View run →</a></p>`;
            main.insertBefore(banner, main.firstChild);

            // Start polling for this run
            if (window.pollForRun) {
              window.pollForRun(banner);
            }
          } else {
            const errorMsg = data.error === 'dispatch_forbidden'
              ? `The GitHub token doesn't have Actions write permission. Use a PAT with "Actions: Read and write" scope.`
              : data.error === 'dispatch_unprocessable'
              ? `Workflow dispatch was rejected by GitHub (422). The workflow may not have workflow_dispatch enabled or the ref is invalid.`
              : `Failed to dispatch the workflow. Check server logs for details.`;

            const banner = document.createElement('div');
            banner.className = 'mb-6 p-4 bg-red-50 border border-red-200 rounded-lg';
            banner.innerHTML = `<p class="text-red-800"><strong>Dispatch failed${repo ? ` (${repo})` : ''}:</strong> ${errorMsg}</p>`;
            main.insertBefore(banner, main.firstChild);
          }
        } catch (e) {
          console.error('Dispatch error:', e);
          const main = document.querySelector('main');
          if (main) {
            const banner = document.createElement('div');
            banner.className = 'mb-6 p-4 bg-red-50 border border-red-200 rounded-lg';
            banner.innerHTML = `<p class="text-red-800"><strong>Dispatch failed for ${repo}:</strong> Network error. Please try again.</p>`;
            main.insertBefore(banner, main.firstChild);
          }
        } finally {
          if (btn) btn.disabled = false;
        }
        return false;
      };

      window.refreshRepo = async function(repoName) {
        const btn = document.querySelector(`button[data-refresh="${repoName}"]`);
        if (btn) btn.disabled = true;
        try {
          const res = await fetch(`/api/repo-status?repo=${encodeURIComponent(repoName)}`);
          if (res.ok) {
            location.reload();
          }
        } finally {
          if (btn) btn.disabled = false;
        }
      };

      window.pollForRun = function(banner) {
        const el = banner;
        const runUrl = banner.dataset.runUrl;
        const repo = banner.dataset.repo ?? '';
        if (!runUrl) return;
        const safeUrl = runUrl;

        const MAX_POLLS = 20;
        let polls = 0;

        function applyState(status, conclusion, htmlUrl) {
          const link = `<a href="${htmlUrl}" target="_blank" rel="noreferrer" class="underline font-medium">View run →</a>`;
          if (status === 'completed') {
            if (conclusion === 'success') {
              el.className = 'mb-6 p-4 bg-green-50 border border-green-200 rounded-lg';
              el.innerHTML = `<p class="text-green-800"><strong>✓ Deployed:</strong> <code class="font-mono">${repo}</code> deployed successfully. ${link}</p>`;
            } else if (conclusion === 'failure') {
              el.className = 'mb-6 p-4 bg-red-50 border border-red-200 rounded-lg';
              el.innerHTML = `<p class="text-red-800"><strong>✕ Deploy failed</strong> for <code class="font-mono">${repo}</code>. ${link}</p>`;
            } else if (conclusion === 'cancelled') {
              el.className = 'mb-6 p-4 bg-slate-100 border border-slate-300 rounded-lg';
              el.innerHTML = `<p class="text-slate-700"><strong>— Deploy cancelled</strong> for <code class="font-mono">${repo}</code>. ${link}</p>`;
            } else {
              el.className = 'mb-6 p-4 bg-slate-100 border border-slate-300 rounded-lg';
              el.innerHTML = `<p class="text-slate-700"><strong>Deploy finished</strong> (<code class="font-mono">${conclusion}</code>) for <code class="font-mono">${repo}</code>. ${link}</p>`;
            }
          } else {
            el.className = 'mb-6 p-4 bg-amber-50 border border-amber-200 rounded-lg';
            el.innerHTML = `<p class="text-amber-800"><strong>⏳ Running:</strong> deploy for <code class="font-mono">${repo}</code>… ${link}</p>`;
          }
        }

        async function poll() {
          polls++;
          try {
            const res = await fetch(`/api/run-status?run_url=${encodeURIComponent(safeUrl)}`);
            if (!res.ok) return;
            const data = await res.json();
            applyState(data.status, data.conclusion, data.html_url || safeUrl);
            if (data.status === 'completed') return;
          } catch (_) {
            // network error — keep trying
          }
          if (polls < MAX_POLLS) {
            setTimeout(poll, 5000);
          } else {
            el.className = 'mb-6 p-4 bg-slate-100 border border-slate-300 rounded-lg';
            el.innerHTML = `<p class="text-slate-700">Deploy for <code class="font-mono">${repo}</code> is taking longer than expected. <a href="${safeUrl}" target="_blank" rel="noreferrer" class="underline font-medium">View run →</a></p>`;
          }
        }

        setTimeout(poll, 3000);
      };
    </script>
  </main>
</Layout>
