---
import { env } from '@/lib/env';
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import PrTable from '@/components/PrTable.astro';
import { cachePRs } from '@/lib/github';

const typedEnv = env;
const token = typedEnv.GITHUB_TOKEN;

const { prs, fetchedAt } = await cachePRs(typedEnv, token);
const now = new Date(fetchedAt).toLocaleString();
---

<Layout title="Release Dashboard - Pull Requests">
  <Navbar currentPage="prs" lastUpdated={now} />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <h2 class="text-2xl font-bold text-slate-900 mb-6">Open Pull Requests</h2>
    <PrTable prs={prs} />
  </main>
</Layout>
