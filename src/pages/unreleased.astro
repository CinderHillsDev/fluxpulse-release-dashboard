---
import { env } from 'cloudflare:workers';
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import ReleaseQueue from '@/components/ReleaseQueue.astro';
import { cacheStatus } from '@/lib/github';
import { GH_OWNER } from '@/repos';

const typedEnv = env as Env;
const token = typedEnv.GITHUB_TOKEN;

const { repos, fetchedAt } = await cacheStatus(typedEnv, token);
const now = new Date(fetchedAt).toLocaleString();

const url = new URL(Astro.request.url);
const dispatchError = url.searchParams.get('dispatch_error');
const dispatchOk = url.searchParams.get('dispatch_ok');
const runUrl = url.searchParams.get('run_url') ?? '';

const dispatchErrorMessages: Record<string, string> = {
  dispatch_forbidden: `The GitHub token doesn't have Actions write permission. Update the GITHUB_TOKEN Cloudflare secret with a PAT that has "Actions: Read and write".`,
  dispatch_unprocessable: `Workflow dispatch was rejected by GitHub (422). The workflow may not have workflow_dispatch enabled or the ref is invalid.`,
  dispatch_failed: `Failed to dispatch the workflow. Check Cloudflare Worker logs for details.`,
};
---

<Layout title="Release Dashboard - Release Queue">
  <Navbar currentPage="unreleased" lastUpdated={now} />

  <main class="max-w-7xl mx-auto px-4 py-8">
    {dispatchError && (
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <p class="text-red-800">
          <strong>Dispatch failed:</strong> {dispatchErrorMessages[dispatchError] || dispatchError}
        </p>
      </div>
    )}
    {dispatchOk && (
      <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg">
        <p class="text-green-800">
          <strong>Dispatched:</strong> workflow triggered for <code class="font-mono">{dispatchOk}</code>.{' '}
          {runUrl ? (
            <a href={runUrl} target="_blank" rel="noreferrer" class="underline font-medium">View run →</a>
          ) : (
            <a href={`https://github.com/${GH_OWNER}/${dispatchOk}/actions`} target="_blank" rel="noreferrer" class="underline font-medium">View on GitHub →</a>
          )}
        </p>
      </div>
    )}

    <div class="mb-6">
      <h2 class="text-2xl font-bold text-slate-900">Release Queue</h2>
      <p class="text-sm text-slate-600 mt-1">
        Merged PRs grouped by which environment is next.
        <span class="text-blue-700 font-medium">Pending UAT</span> are queued for the next UAT deploy;
        <span class="text-green-700 font-medium">Pending Prod</span> are already in UAT and ready to promote.
      </p>
    </div>
    <ReleaseQueue repos={repos} />
  </main>
</Layout>
