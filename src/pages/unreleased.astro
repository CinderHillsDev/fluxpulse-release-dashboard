---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import UnreleasedList from '@/components/UnreleasedList.astro';
import { cacheStatus } from '@/lib/github';

const env = Astro.locals.runtime.env;
const token = env.GITHUB_TOKEN;

const repos = await cacheStatus(env, token);
const now = new Date().toLocaleString();
---

<Layout title="Release Dashboard - Unreleased">
  <Navbar currentPage="unreleased" lastUpdated={now} />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <h2 class="text-2xl font-bold text-slate-900 mb-6">Unreleased Commits</h2>
    <UnreleasedList repos={repos} />
  </main>
</Layout>
