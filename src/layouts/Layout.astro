---
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Release Dashboard' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50">
    <slot />

    <script>
      // Auto-refresh countdown — 60 seconds, resets on user interaction
      const COUNTDOWN_START = 60;
      let remaining = COUNTDOWN_START;
      let intervalId: ReturnType<typeof setInterval>;

      function updateDisplay() {
        const el = document.getElementById('auto-refresh-countdown');
        if (el) el.textContent = `${remaining}s`;
      }

      function resetCountdown() {
        remaining = COUNTDOWN_START;
        updateDisplay();
      }

      function tick() {
        remaining -= 1;
        updateDisplay();
        if (remaining <= 0) {
          clearInterval(intervalId);
          location.reload();
        }
      }

      // Start ticking once DOM is ready
      document.addEventListener('DOMContentLoaded', () => {
        updateDisplay();
        intervalId = setInterval(tick, 1000);
      });

      // Reset countdown on any active user interaction
      ['click', 'keydown', 'scroll', 'mousemove', 'touchstart'].forEach((evt) => {
        document.addEventListener(evt, resetCountdown, { passive: true });
      });
    </script>
  </body>
</html>

<style is:global>
  html {
    color-scheme: light;
  }

  body {
    margin: 0;
    padding: 0;
    font-family: system-ui, -apple-system, sans-serif;
  }
</style>
