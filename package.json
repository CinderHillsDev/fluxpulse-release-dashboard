{
  "name": "fluxpulse-release-dashboard",
  "version": "0.1.0",
  "type": "module",
  "description": "Multi-repo release management dashboard for FluxPulse (Astro + Cloudflare Workers)",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "typecheck": "astro check",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy --env production"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^13.3.0",
    "astro": "^6.2.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250102.0",
    "wrangler": "^4.88.0"
  }
}
